#
# On-prem (K3s) platform defaults
# Applied after defaults.yaml.gotmpl for all onprem-* profiles.
# K3s bundles metrics-server, traefik, and coredns — no need to reinstall them.

# ─── Database (local PostgreSQL) ─────────────────────────────────────────────
database:
  type: {{ env "EMF_DB_TYPE" | default "local" | quote }}
  ssl: {{ env "EMF_DB_SSL" | default "false" }}

# ─── K3s bundled components — disable helm-managed duplicates ────────────────
k8s-metrics-server:
  enabled: false

# ─── AWS-only services — disabled on-prem ────────────────────────────────────
aws-lb:
  enabled: false
aws-lb-tgb:
  enabled: false
aws-sm-proxy:
  enabled: false
aws-sm-get-rs-token:
  enabled: false
cluster-autoscaler:
  enabled: false
vertical-pod-autoscaler:
  enabled: false
secret-wait-azure-ad-creds:
  enabled: false
secret-wait-rs-token:
  enabled: false
wait-istio-job:
  enabled: false

# ─── On-prem defaults ───────────────────────────────────────────────────────
oci-secret:
  enabled: false
rs-image-pull-secrets:
  enabled: false
copy-rs-token-to-cluster:
  enabled: false
token-refresh:
  enabled: false
botkube:
  enabled: false
ingress-nginx:
  enabled: false
squid-proxy:
  enabled: false
