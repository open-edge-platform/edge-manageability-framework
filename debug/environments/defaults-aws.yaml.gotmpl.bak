#
# AWS (EKS) platform defaults
# Applied after defaults.yaml.gotmpl for the aws profile.
# EKS does NOT bundle metrics-server — enable it here.

# ─── Database (Aurora) ───────────────────────────────────────────────────────
database:
  type: {{ env "EMF_DB_TYPE" | default "aurora" | quote }}
  ssl: {{ env "EMF_DB_SSL" | default "true" }}

# ─── EKS needs metrics-server installed via helm ─────────────────────────────
k8s-metrics-server:
  enabled: true

# ─── AWS services enabled ───────────────────────────────────────────────────
aws-lb:
  enabled: {{ env "EMF_ENABLE_AWS_LB" | default "true" }}
aws-lb-tgb:
  enabled: {{ env "EMF_ENABLE_AWS_LB" | default "true" }}
aws-sm-proxy:
  enabled: {{ env "EMF_ENABLE_AWS_SM" | default "true" }}
aws-sm-get-rs-token:
  enabled: {{ env "EMF_ENABLE_AWS_SM" | default "true" }}
cluster-autoscaler:
  enabled: {{ env "EMF_ENABLE_AUTOSCALER" | default "true" }}
vertical-pod-autoscaler:
  enabled: {{ env "EMF_ENABLE_VPA" | default "true" }}
secret-wait-azure-ad-creds:
  enabled: true
secret-wait-rs-token:
  enabled: true
wait-istio-job:
  enabled: true
oci-secret:
  enabled: true
rs-image-pull-secrets:
  enabled: true
copy-rs-token-to-cluster:
  enabled: true
token-refresh:
  enabled: true
botkube:
  enabled: true
ingress-nginx:
  enabled: true
squid-proxy:
  enabled: {{ env "EMF_ENABLE_SQUID" | default "true" }}
