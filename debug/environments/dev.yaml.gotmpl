#
# Dev environment (KIND cluster)
# This Profile file is only used for Intel internal testing in KIND environment.

clusterName: {{ env "EMF_CLUSTER_NAME" | default "dev" | quote }}
clusterDomain: {{ env "EMF_CLUSTER_DOMAIN" | default "kind.internal" | quote }}

# Dev-specific database settings
database:
  type: {{ env "EMF_DB_TYPE" | default "local" | quote }}
  ssl: {{ env "EMF_DB_SSL" | default "false" }}

catalog:
  storageClass: {{ env "EMF_STORAGE_CLASS" | default "" | quote }}
  storageSize: {{ env "EMF_CATALOG_STORAGE_SIZE" | default "1Gi" | quote }}

adm:
  deploymentNamespace: {{ env "EMF_ADM_NAMESPACE" | default "fleet-default" | quote }}
  helmSecretName: {{ env "EMF_HELM_SECRET" | default "intel-reg-secret" | quote }}

git:
  provider: {{ env "EMF_GIT_PROVIDER" | default "gitea" | quote }}
{{- if env "EMF_GIT_SERVER" }}
  gitServer: {{ env "EMF_GIT_SERVER" | quote }}
{{- end }}

harbor:
  storageClass: {{ env "EMF_STORAGE_CLASS" | default "" | quote }}
  registrySize: {{ env "EMF_HARBOR_REGISTRY_SIZE" | default "1Gi" | quote }}
  jobLogSize: {{ env "EMF_HARBOR_JOB_LOG_SIZE" | default "100Mi" | quote }}

vault:
  ha: {{ env "EMF_VAULT_HA" | default "false" }}
  replicas: {{ env "EMF_VAULT_REPLICAS" | default "1" }}
  autoInit: {{ env "EMF_VAULT_AUTO_INIT" | default "true" }}
  autoUnseal: {{ env "EMF_VAULT_AUTO_UNSEAL" | default "false" }}
  authorizedAddrs: {{ env "EMF_VAULT_ALLOWED_CIDRS" | default "0.0.0.0/0" | quote }}

tlsSecret: {{ env "EMF_TLS_SECRET" | default "tls-orch" | quote }}
imagePullSecrets: []
