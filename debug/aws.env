# Edge Manageability Framework - AWS Environment Variables
# Usage: set -a; source aws.env; set +a; helmfile -e aws sync

# ─── Cluster Configuration ──────────────────────────────────────────────────
EMF_CLUSTER_NAME=bkc
EMF_CLUSTER_DOMAIN=bkc.edgeorchestrator.intel.com
# EMF_ADMIN_EMAIL=

# ─── Container Registry (single source for all chart/image/OCI/file URLs) ──
# EMF_REGISTRY=registry-rs.edgeorchestration.intel.com/edge-orch

# ─── TLS ────────────────────────────────────────────────────────────────────
# EMF_TLS_SECRET=tls-orch
# EMF_GENERATE_CERT=true
# EMF_TRAEFIK_TLS_OPTION=gateway-tls

# ─── Database (Aurora for AWS) ───────────────────────────────────────────────
EMF_DB_TYPE=aurora
EMF_DB_SSL=true
# EMF_PG_INSTANCES=1
# EMF_PG_STORAGE_SIZE=8Gi
# EMF_PG_MAX_CONNECTIONS=200
# EMF_PG_SHARED_BUFFERS=256MB
# EMF_PG_RESOURCES_PRESET=large

# ─── Storage (EFS for AWS) ───────────────────────────────────────────────────
EMF_STORAGE_CLASS=efs-999
# EMF_CATALOG_STORAGE_SIZE=5Gi
EMF_HARBOR_REGISTRY_SIZE=200Gi
EMF_HARBOR_JOB_LOG_SIZE=10Gi

# ─── Git Provider ───────────────────────────────────────────────────────────
# EMF_GIT_PROVIDER=gitea
# EMF_GIT_SERVER=https://gitea-http.gitea.svc.cluster.local

# ─── Vault (HA enabled for AWS) ────────────────────────────────────────────
EMF_VAULT_HA=true
EMF_VAULT_REPLICAS=3
EMF_VAULT_AUTO_INIT=true
EMF_VAULT_AUTO_UNSEAL=true
# EMF_VAULT_ALLOWED_CIDRS=0.0.0.0/0
# EMF_VAULT_IMAGE_TAG=1.21.3
# EMF_VAULT_LOG_LEVEL=info

# ─── Deployment ─────────────────────────────────────────────────────────────
# EMF_ADM_NAMESPACE=fleet-default
# EMF_HELM_SECRET=intel-reg-secret
# EMF_VERSION=

# ─── Proxy (set all three when using proxy) ─────────────────────────────────
# EMF_HTTP_PROXY=
# EMF_HTTPS_PROXY=
# EMF_NO_PROXY=

# ─── AWS ────────────────────────────────────────────────────────────────────
EMF_AWS_REGION=us-west-2
EMF_AWS_ACCOUNT=123456789012
# EMF_AWS_S3_BUCKET_PREFIX=
# EMF_AWS_SM_SECRET=release-service-token-prod
# EMF_AWS_SM_PROXY_REGION=us-west-2

# ─── AWS EFS ────────────────────────────────────────────────────────────────
# EMF_AWS_EFS_REPOSITORY=602401143452.dkr.ecr.us-west-2.amazonaws.com/eks/aws-efs-csi-driver
# EMF_AWS_EFS_FSID=

# ─── AWS Target Groups (from Terraform output) ─────────────────────────────
# EMF_AWS_TG_TRAEFIK=
# EMF_AWS_TG_TRAEFIK_GRPC=
# EMF_AWS_TG_ARGOCD=

# ─── Traefik ───────────────────────────────────────────────────────────────
EMF_TRAEFIK_SVC_TYPE=NodePort
EMF_TRAEFIK_TLS_OPTION=

# ─── Infra Onboarding ──────────────────────────────────────────────────────
# EMF_DKAM_MODE=prod
# EMF_DKAM_SC=efs-1000
# EMF_DKAM_EXTRA_HOST=
# EMF_TINKERBELL_SC=efs-1000
# EMF_ONBOARDING_SC=efs-1000
# EMF_NET_IP=dynamic
# EMF_NAME_SERVERS=8.8.8.8
# EMF_RS_TYPE=no-auth
# EMF_INFRA_USERNAME=
# EMF_INFRA_PASSWORD=

# ─── Observability ──────────────────────────────────────────────────────────
EMF_O11Y_SRE_LABEL=bkc
EMF_O11Y_DEDICATED_EN=true
EMF_O11Y_STORAGE_CLASS=gp3
EMF_SRE_TLS_ENABLED=true
# EMF_SRE_CA_SECRET_ENABLED=false
# EMF_SMTP_URL=
# EMF_SMTP_SKIP_VERIFY=false

# ─── UI ─────────────────────────────────────────────────────────────────────
# EMF_CORS_ENABLED=true
# EMF_UI_INGRESS_INFRA=false
# EMF_UI_SESSION_TIMEOUT=3600

# ─── Feature Toggles (AWS-specific defaults) ───────────────────────────────
EMF_ENABLE_AWS_LB=true
EMF_ENABLE_AWS_SM=true
EMF_ENABLE_AUTOSCALER=true
EMF_ENABLE_VPA=true
EMF_ENABLE_SQUID=true
EMF_ENABLE_PXE=false
