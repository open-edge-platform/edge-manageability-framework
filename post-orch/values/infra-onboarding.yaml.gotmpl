#
# Infra-onboarding values — all overridable via environment layers
# Reference: argocd/applications/infra-onboarding/custom/infra-onboarding.tpl

---
# ─── Shorthand variables ────────────────────────────────────────────────────
{{- $io       := index .Values "infra-onboarding" | default dict }}
{{- $skipOS   := dig "skipOSProvisioning" false $io }}
{{- $metrics  := dig "enableMetrics" false $io }}
{{- $tracing  := dig "enableTracing" false $io }}
{{- $mode     := dig "dkamMode" "prod" $io }}
{{- $sc       := .Values.storageClass }}
{{- $domain   := .Values.clusterDomain }}
{{- $proxy    := dig "proxy" (dict) .Values }}
{{- $httpProxy     := dig "httpProxy" "" $proxy }}
{{- $httpsProxy    := dig "httpsProxy" "" $proxy }}
{{- $noProxy       := dig "noProxy" "" $proxy }}
{{- $enHttpProxy   := dig "enHttpProxy" "" $proxy }}
{{- $enHttpsProxy  := dig "enHttpsProxy" "" $proxy }}
{{- $enFtpProxy    := dig "enFtpProxy" "" $proxy }}
{{- $enSocksProxy  := dig "enSocksProxy" "" $proxy }}
{{- $enNoProxy     := dig "enNoProxy" "" $proxy }}

# ═════════════════════════════════════════════════════════════════════════════
# Global
# ═════════════════════════════════════════════════════════════════════════════
global:
  registry:
    name: "{{ .Values.containerRegistryURL }}/"
    {{- if .Values.imagePullSecrets }}
    imagePullSecrets:
      {{- toYaml .Values.imagePullSecrets | nindent 6 }}
    {{- else }}
    imagePullSecrets: []
    {{- end }}

# ═════════════════════════════════════════════════════════════════════════════
# Sub-chart toggles
# ═════════════════════════════════════════════════════════════════════════════
import:
  dkam:
    enabled: {{ dig "dkam" "enabled" true $io }}
  tinkerbell:
    enabled: {{ dig "tinkerbell" "enabled" true $io }}
  onboarding-manager:
    enabled: {{ dig "onboarding-manager" "enabled" true $io }}
  pxe-server:
    enabled: {{ if .Values.pxe }}{{ .Values.pxe.enabled }}{{ else }}false{{ end }}
  infra-config:
    enabled: {{ dig "infra-config" "enabled" true $io }}

# ═════════════════════════════════════════════════════════════════════════════
# PXE Server  (only rendered when pxe is enabled)
# ═════════════════════════════════════════════════════════════════════════════
{{- if and .Values.pxe (eq (.Values.pxe.enabled | toString) "true") }}
pxe-server:
  config:
    interface: {{ .Values.pxe.interface | default "" | quote }}
    bootServerIP: {{ .Values.pxe.bootServerIP | default "" | quote }}
    subnetAddress: {{ .Values.pxe.subnetAddress | default "" | quote }}
{{- end }}

# ═════════════════════════════════════════════════════════════════════════════
# Tinkerbell  (disabled entirely when skipOSProvisioning=true)
# ═════════════════════════════════════════════════════════════════════════════
tinkerbell:
  pvc:
    enabled: false
    storageClassName: {{ dig "tinkerbellStorageClass" $sc $io }}
    accessModes: [ReadWriteOnce]

  traefikReverseProxy:
    gatewayNamespace: orch-gateway
    enabled: &traefikRP true
    tinkServerDnsname: "tinkerbell-server.{{ $domain }}"
    nginxDnsname: &nginxDns "tinkerbell-haproxy.{{ $domain }}{{ if ne (.Values.haproxyPort | default "443" | toString) "443" }}:{{ .Values.haproxyPort }}{{ end }}"
  traefikApiGroup: "traefik.io/v1alpha1"

  # ── Nginx CDN stack (resources via resource-overrides.yaml) ──────────────
  stack:
    enabled: true
    {{- if $skipOS }}
    hook:
      enabled: false
    {{- end }}

  # ── Tink controller / server ─────────────────────────────────────────────
  tinkerbell_tink:
    enabled: {{ not $skipOS }}
    controller:
      enabled: {{ not $skipOS }}
    server:
      enabled: {{ not $skipOS }}
      metrics:
        enabled: {{ $metrics }}

  # ── DHCP / iPXE (smee) ──────────────────────────────────────────────────
  tinkerbell_smee:
    {{- if $skipOS }}
    enabled: false
    {{- end }}
    additionalKernelArgs:
      - "http_proxy={{ $enHttpProxy }}"
      - "https_proxy={{ $enHttpsProxy }}"
      - "no_proxy={{ $enNoProxy }}"
      - "HTTP_PROXY={{ $enHttpProxy }}"
      - "HTTPS_PROXY={{ $enHttpsProxy }}"
      - "NO_PROXY={{ $enNoProxy }}"
      - "DEBUG=false"
      - "TIMEOUT=120s"
      - "syslog_host=127.0.0.1"
    traefikReverseProxy:
      enabled: *traefikRP
      nginxDnsname: *nginxDns

  # ── Metadata service (hegel) ─────────────────────────────────────────────
  tinkerbell_hegel:
    {{- if $skipOS }}
    enabled: false
    {{- end }}

# ═════════════════════════════════════════════════════════════════════════════
# Onboarding Manager
# ═════════════════════════════════════════════════════════════════════════════
onboarding-manager:
  service:
    enableIO: {{ dig "onboarding-manager" "service" "enableIO" true $io }}
  managerArgs:
    inventoryAddress: "inventory.orch-infra.svc.cluster.local:50051"
    traceURL: "orchestrator-observability-opentelemetry-collector.orch-platform.svc:4318"
    enableTracing: {{ $tracing }}
  metrics:
    enabled: {{ $metrics }}
  pvc:
    storageClassName: {{ dig "onboardingManagerStorageClass" $sc $io }}

  # ── Ingress ──────────────────────────────────────────────────────────────
  traefikReverseProxy:
    enabled: true
    secretName: "tls-orch"
    gatewayNamespace: orch-gateway
    host:
      grpc:
        name: "onboarding-node.{{ $domain }}"
      stream:
        name: "onboarding-stream.{{ $domain }}"
    tlsOption: {{ dig "tlsOption" "gateway-tls" (.Values.traefik | default dict) | quote }}
  traefikApiGroup: "traefik.io/v1alpha1"

  # ── Runtime config ───────────────────────────────────────────────────────
  env:
    tinkerActionsVersion: "1.21.1"
    oidc:
      oidc_server_url: "http://platform-keycloak.orch-platform.svc/realms/master"
      clients:
        bypass: [cdn-boots]
    vaultUrl: "http://vault.orch-platform.svc.cluster.local:8200"
    vaultRole: "orch-svc"
    keycloakUrl: "http://platform-keycloak.orch-platform.svc.cluster.local:8080"
    mode: {{ $mode | quote }}
    userName: {{ dig "userName" "user" $io | quote }}
    passWord: {{ dig "passWord" "user" $io | quote }}
    enableTinkActionTimestamp: {{ dig "enableTinkActionTimestamp" false $io }}
  multiTenancy:
    enforceMultiTenancy: true
  {{- if (hasKey $io "enServiceClients") }}
  enServiceClients: {{ $io.enServiceClients | quote }}
  {{- end }}
  serviceAccount:
    name: "orch-svc"
  # Resources: managed by resource-overrides.yaml

# ═════════════════════════════════════════════════════════════════════════════
# DKAM
# ═════════════════════════════════════════════════════════════════════════════
dkam:
  pvc:
    storageClassName: {{ dig "dkamStorageClass" $sc $io }}
  managerArgs:
    traceURL: "orchestrator-observability-opentelemetry-collector.orch-platform.svc:4318"
    enableTracing: {{ $tracing }}
  {{- if and (index .Values "infra-external") (dig "loca" false (index .Values "infra-external")) }}
    legacyMode: true
  {{- end }}
  metrics:
    enabled: {{ $metrics }}
  env:
    rs_proxy_address: "rs-proxy.orch-platform.svc.cluster.local:8081/"
    oidc:
      oidc_server_url: "http://platform-keycloak.orch-platform.svc/realms/master"
    mode: {{ $mode | quote }}
  proxies:
    http_proxy: {{ $httpProxy }}
    https_proxy: {{ $httpsProxy }}
    no_proxy: {{ $noProxy }}
  # Resources: managed by resource-overrides.yaml

# ═════════════════════════════════════════════════════════════════════════════
# Infra Config  (edge-node agent configuration pushed during onboarding)
# ═════════════════════════════════════════════════════════════════════════════
infra-config:
  config:
    # ── Agent versions ───────────────────────────────────────────────────────
    enAgentManifestTag: "1.6.4"
    embImageUrl: files-edge-orch/repository/microvisor/uos/emb_uos_x86_64_20260507.tar.gz

    # ── Edge-node proxy settings ─────────────────────────────────────────────
    enProxyHTTP: {{ $enHttpProxy }}
    enProxyHTTPS: {{ $enHttpsProxy }}
    enProxyFTP: {{ $enFtpProxy }}
    enProxySocks: {{ $enSocksProxy }}
    enProxyNoProxy: {{ $enNoProxy }}

    # ── Orchestrator service endpoints ───────────────────────────────────────
    orchInfra: infra-node.{{ $domain }}:443
    orchCluster: cluster-orch-node.{{ $domain }}:443
    orchUpdate: update-node.{{ $domain }}:443
    orchRelease: release.{{ $domain }}
    orchPlatformObsLogs: logs-node.{{ $domain }}:443
    orchPlatformObsMetrics: metrics-node.{{ $domain }}:443
    orchKeycloak: keycloak.{{ $domain }}:443
    orchTelemetry: telemetry-node.{{ $domain }}:443
    orchAttestationStatus: attest-node.{{ $domain }}:443
    orchRegistry: {{ .Values.releaseService.ociRegistry }}:9443
    orchFileServer: {{ .Values.releaseService.fileServer }}:60444
    # TODO: Revisit the below routes — limit exposure and switch to MT GW endpoints
    orchMPSHost: mps.{{ $domain }}:4433
    orchMPSWHost: mps-wss.{{ $domain }}:443
    orchRPSHost: rps.{{ $domain }}:443
    orchRPSWHost: rps-wss.{{ $domain }}:443
    orchDeviceManager: device-manager-node.{{ $domain }}:443

    # ── Internal service endpoints ───────────────────────────────────────────
    cdnSvc: {{ .Values.releaseService.fileServer }}
    provisioningSvc: tinkerbell-haproxy.{{ $domain }}{{ if ne (.Values.haproxyPort | default "443" | toString) "443" }}:{{ .Values.haproxyPort }}{{ end }}
    tinkerSvc: tinkerbell-server.{{ $domain }}
    omSvc: onboarding-node.{{ $domain }}
    omStreamSvc: onboarding-stream.{{ $domain }}

    # ── Agent client lists (overridable per profile) ─────────────────────────
    rsType: {{ dig "rsType" "no-auth" $io | quote }}
    enServiceClients: {{ dig "enServiceClients" "hardware-discovery-agent,cluster-agent,platform-manageability-agent,platform-update-agent,platform-telemetry-agent" $io | quote }}
    enOutboundClients: {{ dig "enOutboundClients" "platform-observability-collector,platform-observability-health-check,platform-observability-logging,platform-observability-metrics" $io | quote }}
    enMetricsEnabled: {{ dig "enMetricsEnabled" "true" $io | quote }}
    enTokenClients: {{ dig "enTokenClients" "node-agent,hd-agent,cluster-agent,platform-update-agent,platform-observability-agent,platform-telemetry-agent,prometheus,connect-agent,attestation-manager,platform-manageability-agent" $io | quote }}

    # ── Profile toggles ─────────────────────────────────────────────────────
    disableCoProfile: {{ dig "disableCoProfile" false $io }}
    disableO11yProfile: {{ dig "disableO11yProfile" false $io }}
    skipOSProvisioning: {{ $skipOS }}
    extraHosts: {{ dig "dkamExtraHost" "" $io | quote }}

    # ── Network settings ─────────────────────────────────────────────────────
    netIp: {{ dig "netIp" "dynamic" $io | quote }}
    ntpServer: {{ dig "ntpServer" "ntp1.server.org,ntp2.server.org" $io | quote }}
    {{- $nameServers := dig "nameServers" list $io }}
    {{- if $nameServers }}
    nameServers:
      {{- toYaml $nameServers | nindent 6 }}
    {{- else }}
    nameServers: []
    {{- end }}

    # ── Kernel / system tuning ───────────────────────────────────────────────
    systemConfigFsInotifyMaxUserInstances: {{ dig "systemConfigFsInotifyMaxUserInstances" "8192" $io | quote }}
    systemConfigVmOverCommitMemory: {{ dig "systemConfigVmOverCommitMemory" "1" $io | quote }}
    systemConfigKernelPanicOnOops: {{ dig "systemConfigKernelPanicOnOops" "1" $io | quote }}
    systemConfigKernelPanic: {{ dig "systemConfigKernelPanic" "10" $io | quote }}

    # ── Firewall rules ───────────────────────────────────────────────────────
    firewallReqAllow: |-
      [{
        "sourceIp": "{{ $domain }}",
        "ports": "6443,10250",
        "ipVer": "ipv4",
        "protocol": "tcp"
      }]
    {{- $fwAllow := dig "firewallCfgAllow" list $io }}
    {{- if $fwAllow }}
    firewallCfgAllow:
      {{- toYaml $fwAllow | nindent 6 }}
    {{- else }}
    firewallCfgAllow: |-
      [{
        "sourceIp": "",
        "ports": "2379,2380,6443,9345,10250,5473",
        "ipVer": "",
        "protocol": "tcp"
      },
      {
        "sourceIp": "",
        "ports": "7946",
        "ipVer": "",
        "protocol": ""
      },
      {
        "sourceIp": "",
        "ports": "123",
        "ipVer": "",
        "protocol": "udp"
      }]
    {{- end }}
