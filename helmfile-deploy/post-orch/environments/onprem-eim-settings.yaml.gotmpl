#
# EIM environment — Part 1: Environment & global settings
# All values driven by post-orch.env (sourced by post-orch-deploy.sh)
# Feature flags are in onprem-eim-features.yaml.gotmpl

# ─── Registry ────────────────────────────────────────────────────────────────
{{- $registryHost := requiredEnv "EMF_REGISTRY" }}
{{- $registry := printf "%s/edge-orch" $registryHost }}
chartRepoURL: {{ $registry | quote }}
rsChartRepoURL: {{ $registry | quote }}
containerRegistryURL: {{ $registry | quote }}

releaseService:
  ociRegistry: {{ $registryHost | quote }}
  fileServer: {{ $registryHost | replace "registry-rs" "files-rs" | quote }}

# ─── Cluster ─────────────────────────────────────────────────────────────────
clusterDomain: {{ requiredEnv "EMF_CLUSTER_DOMAIN" | quote }}

# ─── TLS ─────────────────────────────────────────────────────────────────────
tlsSecret: {{ env "EMF_TLS_SECRET" | default "tls-orch" | quote }}
imagePullSecrets: []

# ─── Storage ─────────────────────────────────────────────────────────────────
storageClass: {{ env "EMF_STORAGE_CLASS" | default "openebs-hostpath" | quote }}

# ─── PostgreSQL tuning ───────────────────────────────────────────────────────
postgresql:
  maxConnections: {{ env "EMF_PG_MAX_CONNECTIONS" | default "200" }}
  sharedBuffers: {{ env "EMF_PG_SHARED_BUFFERS" | default "256MB" | quote }}

# ─── Storage / Catalog ───────────────────────────────────────────────────────
catalog:
  storageClass: {{ env "EMF_STORAGE_CLASS" | default "openebs-hostpath" | quote }}
  storageSize: {{ env "EMF_CATALOG_STORAGE_SIZE" | default "5Gi" | quote }}

# ─── Application Deployment ──────────────────────────────────────────────────
adm:
  deploymentNamespace: {{ env "EMF_ADM_NAMESPACE" | default "fleet-default" | quote }}
  helmSecretName: {{ env "EMF_HELM_SECRET" | default "intel-reg-secret" | quote }}

# ─── Git ─────────────────────────────────────────────────────────────────────
git:
  gitServer: {{ env "EMF_GIT_SERVER" | default "https://gitea-http.gitea.svc.cluster.local" | quote }}
  provider: {{ env "EMF_GIT_PROVIDER" | default "gitea" | quote }}

# ─── Harbor ──────────────────────────────────────────────────────────────────
harbor:
  storageClass: {{ env "EMF_STORAGE_CLASS" | default "openebs-hostpath" | quote }}
  registrySize: {{ env "EMF_HARBOR_REGISTRY_SIZE" | default "100Gi" | quote }}
  jobLogSize: {{ env "EMF_HARBOR_JOB_LOG_SIZE" | default "1Gi" | quote }}

# ─── Database (local PostgreSQL on K3s) ──────────────────────────────────────
database:
  type: {{ env "EMF_DB_TYPE" | default "local" | quote }}
  ssl: {{ env "EMF_DB_SSL" | default "false" }}
  databases:
    - namespace: orch-platform
      name: platform-keycloak
    - namespace: orch-platform
      name: vault
    - namespace: orch-infra
      name: inventory
    - namespace: orch-infra
      name: alerting
    - namespace: orch-iam
      name: iam-tenancy
    - namespace: orch-infra
      name: mps
    - namespace: orch-infra
      name: rps

# ─── Istio ───────────────────────────────────────────────────────────────────
istio:
  enabled: {{ env "EMF_ENABLE_ISTIO" | default "false" }}
istio-base:
  enabled: {{ env "EMF_ENABLE_ISTIO" | default "false" }}
istio-policy:
  enabled: {{ env "EMF_ENABLE_ISTIO" | default "false" }}
istiod:
  enabled: {{ env "EMF_ENABLE_ISTIO" | default "false" }}
kiali:
  enabled: {{ env "EMF_ENABLE_ISTIO" | default "false" }}
wait-istio-job:
  enabled: {{ env "EMF_ENABLE_ISTIO" | default "false" }}

# ─── Kyverno ─────────────────────────────────────────────────────────────────
kyverno:
  enabled: {{ env "EMF_ENABLE_KYVERNO" | default "false" }}
kyverno-extra-policies:
  enabled: {{ env "EMF_ENABLE_KYVERNO" | default "false" }}
kyverno-istio-policy:
  enabled: {{ env "EMF_ENABLE_KYVERNO" | default "false" }}
kyverno-traefik-policy:
  enabled: {{ env "EMF_ENABLE_KYVERNO" | default "false" }}

# ─── Traefik ─────────────────────────────────────────────────────────────────
traefik:
  enabled: true
  tlsOption: {{ env "EMF_TRAEFIK_TLS_OPTION" | default "gateway-tls" | quote }}

# ─── Single-IP mode ─────────────────────────────────────────────────────────
# When EMF_ORCH_IP is set, all LoadBalancer services share one IP on different ports.
# Traefik: 443, HAProxy: 9443
singleIpMode: {{ if env "EMF_ORCH_IP" }}true{{ else }}false{{ end }}
haproxyPort: {{ if env "EMF_ORCH_IP" }}9443{{ else }}443{{ end }}

orchestratorVersion: {{ env "EMF_VERSION" | default (readFile "../../../VERSION" | trim) | quote }}

# ─── Vault config ────────────────────────────────────────────────────────────
vault:
  enabled: true
  ha: {{ env "EMF_VAULT_HA" | default "false" }}
  replicas: {{ env "EMF_VAULT_REPLICAS" | default "1" }}
  autoInit: {{ env "EMF_VAULT_AUTO_INIT" | default "true" }}
  autoUnseal: {{ env "EMF_VAULT_AUTO_UNSEAL" | default "false" }}
  authorizedAddrs: {{ env "EMF_VAULT_ALLOWED_CIDRS" | default "0.0.0.0/0" | quote }}

# ─── Certificates ────────────────────────────────────────────────────────────
self-signed-cert:
  enabled: true
  generateOrchCert: {{ env "EMF_GENERATE_CERT" | default "true" }}

# ─── Deployment target ───────────────────────────────────────────────────────
orchestratorDeployment:
  targetCluster: {{ env "EMF_TARGET_CLUSTER" | default "onprem" | quote }}

# ─── Proxy (only if EMF_HTTP_PROXY is set in post-orch.env) ────────────────────
{{- if env "EMF_HTTP_PROXY" }}
proxy:
  httpProxy: {{ env "EMF_HTTP_PROXY" | quote }}
  httpsProxy: {{ env "EMF_HTTPS_PROXY" | default "" | quote }}
  noProxy: {{ env "EMF_NO_PROXY" | default "" | quote }}
  enHttpProxy: {{ env "EMF_EN_HTTP_PROXY" | default (env "EMF_HTTP_PROXY") | quote }}
  enHttpsProxy: {{ env "EMF_EN_HTTPS_PROXY" | default (env "EMF_HTTPS_PROXY") | quote }}
  enFtpProxy: {{ env "EMF_EN_FTP_PROXY" | default "" | quote }}
  enSocksProxy: {{ env "EMF_EN_SOCKS_PROXY" | default "" | quote }}
  enNoProxy: {{ env "EMF_EN_NO_PROXY" | default (env "EMF_NO_PROXY") | quote }}
{{- end }}

# ─── PXE / OXM ──────────────────────────────────────────────────────────────
pxe:
  enabled: {{ env "EMF_ENABLE_PXE" | default "false" }}
{{- if env "EMF_OXM_PXE_SERVER_INT" }}
  interface: {{ env "EMF_OXM_PXE_SERVER_INT" | quote }}
  bootServerIP: {{ env "EMF_OXM_PXE_SERVER_IP" | quote }}
  subnetAddress: {{ env "EMF_OXM_PXE_SERVER_SUBNET" | quote }}
{{- end }}

# ─── O11y replica settings ──────────────────────────────────────────────────
o11y:
  alertingMonitor:
    minReplicas: {{ env "EMF_ALERTING_MIN_REPLICAS" | default "1" }}
    maxReplicas: {{ env "EMF_ALERTING_MAX_REPLICAS" | default "1" }}
    alertmanagerReplicas: {{ env "EMF_ALERTMANAGER_REPLICAS" | default "1" }}
    smtpInitialize: {{ env "EMF_SMTP_INITIALIZE" | default "false" }}

