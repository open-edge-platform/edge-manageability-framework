#
# vPro profile overrides — layered on top of:
#   defaults-disabled → onprem-eim-settings → onprem-eim-features
#
# Reference: orch-configs/profiles/enable-edgeinfra-vpro.yaml
# This enables Modular vPro Edge Infrastructure Manager to support 100 edge nodes.
# This file ONLY contains values that DIFFER from the EIM features.

# ═══════════════════════════════════════════════════════════════════════════════
# Releases to DISABLE (enabled in EIM features, not needed for vPro)
# ═══════════════════════════════════════════════════════════════════════════════
web-ui-root:
  enabled: false
web-ui-infra:
  enabled: false
web-ui-admin:
  enabled: false
metadata-broker:
  enabled: false
ingress-haproxy:
  enabled: false
haproxy-ingress-pxe-boots:
  enabled: false
certificate-file-server:
  enabled: true
  # Disable boots-ca-cert dependency for vPro (boots infrastructure disabled)
  secretName: ""
secret-wait-tls-boots:
  enabled: false
copy-ca-cert-boots-to-gateway:
  enabled: false
copy-ca-cert-boots-to-infra:
  enabled: false
auth-service:
  enabled: false
namespace-labe:
  enabled: false
platform-autocert:
  enabled: false
copy-ca-cert-gateway-to-cattle:
  enabled: false
token-fs:
  enabled: false
infra-managers:
  enabled: true
  disabledProvisioning: true
  host-manager:
    enabled: true
  maintenance-manager:
      enabled: false
  telemetry-manager:
    enabled: false
  os-resource-manager:
    enabled: false
  networking-manager:
    enabled: false
  attestationstatus-manager:
    enabled: false
# ═══════════════════════════════════════════════════════════════════════════════
# Releases to ENABLE (disabled in defaults, needed for vPro)
# ═══════════════════════════════════════════════════════════════════════════════
# ═══════════════════════════════════════════════════════════════════════════════
# infra-core overrides (from enable-edgeinfra-vpro.yaml)
# ═══════════════════════════════════════════════════════════════════════════════
infra-core:
  enabled: true
  eimScenario: vpro
  skipOSProvisioning: true
  tenant-config:
    enabled: false
  credentials:
    enabled: true
  api:
    enabled: false
  apiv2:
    enabled: true
  exporter:
    enabled: false
  inventory:
    enabled: true
  tenant-controller:
    enabled: true

# ═══════════════════════════════════════════════════════════════════════════════
# infra-onboarding overrides (from enable-edgeinfra-vpro.yaml)
# ═══════════════════════════════════════════════════════════════════════════════
infra-onboarding:
  enabled: true
  skipOSProvisioning: true
  enServiceClients: "platform-manageability-agent"
  enOutboundClients: " "
  enMetricsEnabled: "false"
  enTokenClients: "node-agent,platform-manageability-agent"
  tinkerbell:
    enabled: false
  pxe-server:
    enabled: false
  infra-config:
    enabled: true
  onboarding-manager:
    enabled: true
    service:
      enableIO: false
  dkam:
    enabled: false

# ═══════════════════════════════════════════════════════════════════════════════
# infra-external overrides (AMT components for vPro)
# ═══════════════════════════════════════════════════════════════════════════════
infra-external:
  enabled: true
  amt:
    mps:
      enabled: true
    rps:
      enabled: true
    dm-manager:
      enabled: true
  loca-manager:
    enabled: false
  loca-metadata-manager:
    enabled: false
  loca-credentials:
    enabled: false
  loca-templates-manager:
    enabled: false

# ═══════════════════════════════════════════════════════════════════════════════
# Optional Releases to ENABLE (disabled in defaults, enable if required)
# ═══════════════════════════════════════════════════════════════════════════════
edgenode-observability:
  enabled: false
edgenode-dashboards:
  enabled: false
observability-tenant-controller:
  enabled: false
