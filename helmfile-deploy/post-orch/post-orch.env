#
# Edge Manageability Framework - On-Premises Environment Variables
# Usage: set -a; source post-orch.env; set +a; helmfile -e onprem-eim sync
#
# Profile options: onprem-eim, onprem-vpro
EMF_HELMFILE_ENV=onprem-eim
# ─── Cluster Configuration ──────────────────────────────────────────────────
EMF_CLUSTER_NAME=onprem
EMF_CLUSTER_DOMAIN=cluster.onprem

# ─── Container Registry (single source for all chart/image/OCI/file URLs) ──
EMF_REGISTRY=registry-rs.edgeorchestration.intel.com

# ─── Storage ────────────────────────────────────────────────────────────────
EMF_STORAGE_CLASS=openebs-hostpath
# EMF_CATALOG_STORAGE_SIZE=5Gi
# EMF_HARBOR_REGISTRY_SIZE=100Gi
# EMF_HARBOR_JOB_LOG_SIZE=1Gi

EMF_SERVICE_TYPE=LoadBalancer

# ─── Load Balancer IPs ──────────────────────────────────────────────────────
EMF_TRAEFIK_IP=192.168.99.30
EMF_HAPROXY_IP=192.168.99.40
#EMF_TRAEFIK_IP=192.168.170.102
#EMF_HAPROXY_IP=192.168.170.101

# ─── Proxy Configuration ───────────────────────────────────────────────────
EMF_HTTP_PROXY=http://proxy-dmz.intel.com:912
EMF_HTTPS_PROXY=http://proxy-dmz.intel.com:912
EMF_NO_PROXY=.caas.intel.com,certificates.intel.com,localhost,127.0.0.0/8,10.0.0.0/8,192.168.0.0/16,172.16.0.0/12,169.254.169.254,.svc,.cluster.local,.default,.internal,.orch-platform,.orch-app,.orch-cluster,.orch-infra,.orch-database,.cattle-system,.orch-secret,.onprem,.espd.infra-host.com,.pid.infra-host.com,.espdqa.infra-host.com

# ─── Edge Node Proxy Configuration ─────────────────────────────────────────
EMF_EN_HTTP_PROXY=http://proxy-dmz.intel.com:912
EMF_EN_HTTPS_PROXY=http://proxy-dmz.intel.com:912
EMF_EN_FTP_PROXY=http://proxy-dmz.intel.com:911
EMF_EN_SOCKS_PROXY=http://proxy-dmz.intel.com:1080
EMF_EN_NO_PROXY=.caas.intel.com,certificates.intel.com,localhost,127.0.0.0/8,10.0.0.0/8,192.168.0.0/16,172.16.0.0/12,169.254.169.254,.svc,.cluster.local,.default,.internal,.orch-platform,.orch-app,.orch-cluster,.orch-infra,.orch-database,.cattle-system,.orch-secret,.onprem,.espd.infra-host.com,.pid.infra-host.com,.espdqa.infra-host.com

EMF_ENABLE_ISTIO=false
EMF_ENABLE_KYVERNO=false
