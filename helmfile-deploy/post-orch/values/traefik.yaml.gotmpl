# Traefik values - configurable via environment
# TLS option from env: {{ .Values.traefik.tlsOption | default "gateway-tls" }}

providers:
  kubernetesCRD:
    allowCrossNamespace: true
    namespaces:
      - "default"
      - "orch-gateway"
      - "orch-platform"
      - "orch-app"
      - "orch-infra"
      - "orch-cluster"
      - "orch-harbor"
      - "cattle-system"
      - "connect-gateway"
      - "orch-ui"
      - "orch-secret"
      - "orch-iam"
ingressRoute:
  dashboard:
    enabled: false

logs:
  general:
    format: json
  access:
    enabled: true
    format: json

volumes:
  - name: jwt-plugin
    type: configMap
    # mount path for the pod is not important when using plugins but it needs to be specified
    mountPath: ./traefik-jwt-plugin/

additionalVolumeMounts:
  - mountPath: ./plugins-local/src/github.com/team-carepay/traefik-jwt-plugin/
    name: jwt-plugin

additionalArguments:
  - --experimental.localPlugins.jwt.moduleName=github.com/team-carepay/traefik-jwt-plugin

metrics:
  prometheus:
    buckets: "0.1,0.3,0.6,0.9,1.2,1.5,2.0,2.5,5.0,10.0"
    service:
      enabled: true

deployment:
  podAnnotations:
{{- if eq (.Values.istio.enabled | toString) "true" }}
    traffic.sidecar.istio.io/excludeInboundPorts: "8000,8443,8080,4433"          # Traefik listened
    traffic.sidecar.istio.io/excludeOutboundPorts: "4433"                        # Traefik MPS passthrough
    # TODO: Make configurable because every k8s cluster is different
    traffic.sidecar.istio.io/excludeOutboundIPRanges: "10.96.0.1/32"        # k8s API server
{{- else }}
    sidecar.istio.io/inject: "false"
{{- end }}

service:
  type: LoadBalancer
{{- if eq (.Values.singleIpMode | toString) "true" }}
  annotations:
    metallb.universe.tf/address-pool: orch-pool
    metallb.universe.tf/allow-shared-ip: orch-services
{{- end }}

ports:
{{- if .Values | getOrNil "squid-proxy.enabled" }}
  squidproxy:
    port: 9000
    exposedPort: 8080
    expose:
      default: true
    protocol: TCP
{{- end }}
  web:
    expose:
      default: false
  websecure:
    nodePort: 30443
    # Breaking change when migrating to v39.0.0. See:
    # https://github.com/traefik/traefik-helm-chart/releases/tag/v39.0.0
    http:
      # NOTE the middleware name is <namespace>-<name>
      middlewares:
        - orch-gateway-rate-limit@kubernetescrd
        {{- if eq (.Values.cors.enabled | toString) "true" }}
        - orch-gateway-cors@kubernetescrd
        {{- end }}
  tcpamt:
    # Breaking change when migrating to v39.0.0. See:
    # https://github.com/traefik/traefik-helm-chart/releases/tag/v39.0.0
    http:
      middlewares:
        - orch-gateway-tcp-rate-limit@kubernetescrd
    port: 4433
    exposedPort: 4433
    expose:
      default: true
    protocol: TCP

resources: {}
nodeSelector: {}
tolerations: []

# modify default Traefik container security context to include seccompProfile
securityContext:
  allowPrivilegeEscalation: false
  capabilities:
    drop: [ALL]
  readOnlyRootFilesystem: true
  seccompProfile:
    type: RuntimeDefault
