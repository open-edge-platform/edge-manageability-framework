# Pre-Orchestrator Configuration
# Usage: source pre-orch.env before running pre-orch.sh
#
# This file is auto-sourced by pre-orch.sh.
# Values here can be overridden by environment variables or CLI flags.

# ─── Kubernetes Provider ────────────────────────────────────────────────────
# Options: kind, k3s, rke2
PROVIDER=k3s

# ─── Kubelet ────────────────────────────────────────────────────────────────
MAX_PODS=500

K3S_VERSION=v1.34.3+k3s1
# RKE2_VERSION=v1.34.4+rke2r1
# KIND_VERSION=v0.27.0
# KIND_CLUSTER_NAME=kind-cluster
# KIND_API_PORT=6443

# ─── Docker Hub Credentials (for K3s/RKE2 registry auth) ─────────
# DOCKER_USERNAME=
# DOCKER_PASSWORD=

# ─── Timeouts ───────────────────────────────────────────────────────────────
# WAIT_TIMEOUT_SECONDS=300
# WAIT_INTERVAL_SECONDS=5

# ─── Pre-orch Components (true/false) ──────────────────────────────────────
INSTALL_OPENEBS=true
INSTALL_METALLB=true
INSTALL_PRE_CONFIG=true

# ─── OpenEBS LocalPV ────────────────────────────────────────────────────────
LOCALPV_VERSION=4.3.0

# ─── MetalLB IPs (required when INSTALL_METALLB=true) ──────────────────────
EMF_TRAEFIK_IP=192.168.99.30
EMF_HAPROXY_IP=192.168.99.40
