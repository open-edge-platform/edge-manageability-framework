    labels:
      istio-injection: {{ if eq (.Values.istio.enabled | toString) "true" }}enabled{{ else }}disabled{{ end }}
  - name: "orch-app"
    labels:
      istio-injection: {{ if eq (.Values.istio.enabled | toString) "true" }}enabled{{ else }}disabled{{ end }}
  - name: "orch-cluster"
    labels:
      istio-injection: {{ if eq (.Values.istio.enabled | toString) "true" }}enabled{{ else }}disabled{{ end }}
  - name: "orch-ui"
    labels:
      istio-injection: {{ if eq (.Values.istio.enabled | toString) "true" }}enabled{{ else }}disabled{{ end }}
  - name: "orch-platform"
    labels:
      istio-injection: {{ if eq (.Values.istio.enabled | toString) "true" }}enabled{{ else }}disabled{{ end }}
  - name: "orch-harbor"
    labels:
      istio-injection: {{ if eq (.Values.istio.enabled | toString) "true" }}enabled{{ else }}disabled{{ end }}
  - name: "orch-gateway"
    labels:
