# Edge Manageability Framework - On-Premises Environment Variables
# Usage: set -a; source onprem.env; set +a; helmfile -e onprem-eim sync
#
# Profile options: onprem, onprem-1k, onprem-oxm, onprem-explicit-proxy, aws,
#                  onprem-vpro, onprem-eim, onprem-eim-co, onprem-eim-co-ao, onprem-eim-co-ao-o11y,
#                  dev, dev-minimal, bkc

# ─── Cluster Configuration ──────────────────────────────────────────────────
EMF_CLUSTER_NAME=onprem
EMF_CLUSTER_DOMAIN=cluster.onprem

# ─── Container Registry (single source for all chart/image/OCI/file URLs) ──
EMF_REGISTRY=registry-rs.edgeorchestration.intel.com

# ─── Docker Hub Credentials ────────────────────────────────────────────────
EMF_DOCKER_USERNAME=''
EMF_DOCKER_PASSWORD=''

# ─── Gitea Container Registry ──────────────────────────────────────────────
EMF_GITEA_IMAGE_REGISTRY=docker.io
EMF_GITEA_ENABLED=false

# ─── TLS ────────────────────────────────────────────────────────────────────
# EMF_TLS_SECRET=tls-orch
# EMF_GENERATE_CERT=true
# EMF_TRAEFIK_TLS_OPTION=gateway-tls

# ─── Database ───────────────────────────────────────────────────────────────
# EMF_DB_TYPE=local
# EMF_DB_SSL=false
# EMF_PG_INSTANCES=1
# EMF_PG_STORAGE_SIZE=8Gi
# EMF_PG_MAX_CONNECTIONS=200
# EMF_PG_SHARED_BUFFERS=256MB
# EMF_PG_RESOURCES_PRESET=large

# ─── Storage ────────────────────────────────────────────────────────────────
EMF_STORAGE_CLASS=openebs-hostpath
# EMF_CATALOG_STORAGE_SIZE=5Gi
# EMF_HARBOR_REGISTRY_SIZE=100Gi
# EMF_HARBOR_JOB_LOG_SIZE=1Gi

# ─── Git Provider ───────────────────────────────────────────────────────────
# EMF_GIT_PROVIDER=gitea
# EMF_GIT_SERVER=https://gitea-http.gitea.svc.cluster.local

# ─── Vault ──────────────────────────────────────────────────────────────────
# EMF_VAULT_HA=false
# EMF_VAULT_REPLICAS=1
# EMF_VAULT_AUTO_INIT=true
# EMF_VAULT_AUTO_UNSEAL=false
# EMF_VAULT_ALLOWED_CIDRS=0.0.0.0/0
# EMF_VAULT_IMAGE_TAG=1.21.3
# EMF_VAULT_LOG_LEVEL=info

# ─── Deployment ─────────────────────────────────────────────────────────────
# EMF_ADM_NAMESPACE=fleet-default
# EMF_HELM_SECRET=intel-reg-secret
# EMF_VERSION=

# ─── Kubernetes ─────────────────────────────────────────────────────────────
# KUBECONFIG=/home/$USER/.kube/config
EMF_SERVICE_TYPE=LoadBalancer

# ─── Load Balancer IPs ──────────────────────────────────────────────────────
EMF_TRAEFIK_IP=192.168.99.30
EMF_HAPROXY_IP=192.168.99.40

# ─── Proxy Configuration ───────────────────────────────────────────────────
EMF_HTTP_PROXY=http://proxy-dmz.intel.com:912
EMF_HTTPS_PROXY=http://proxy-dmz.intel.com:912
EMF_NO_PROXY=.caas.intel.com,certificates.intel.com,localhost,127.0.0.0/8,10.0.0.0/8,192.168.0.0/16,172.16.0.0/12,169.254.169.254,.svc,.cluster.local,.default,.internal,.orch-platform,.orch-app,.orch-cluster,.orch-infra,.orch-database,.cattle-system,.orch-secret,.onprem,.espd.infra-host.com,.pid.infra-host.com,.espdqa.infra-host.com

# ─── Edge Node Proxy Configuration ─────────────────────────────────────────
EMF_EN_HTTP_PROXY=http://proxy-dmz.intel.com:912
EMF_EN_HTTPS_PROXY=http://proxy-dmz.intel.com:912
EMF_EN_FTP_PROXY=http://proxy-dmz.intel.com:911
EMF_EN_SOCKS_PROXY=http://proxy-dmz.intel.com:1080
EMF_EN_NO_PROXY=.caas.intel.com,certificates.intel.com,localhost,127.0.0.0/8,10.0.0.0/8,192.168.0.0/16,172.16.0.0/12,169.254.169.254,.svc,.cluster.local,.default,.internal,.orch-platform,.orch-app,.orch-cluster,.orch-infra,.orch-database,.cattle-system,.orch-secret,.onprem,.espd.infra-host.com,.pid.infra-host.com,.espdqa.infra-host.com

# ─── OXM Network Configuration ─────────────────────────────────────────────
# EMF_OXM_PXE_SERVER_INT=
# EMF_OXM_PXE_SERVER_IP=
# EMF_OXM_PXE_SERVER_SUBNET=

# ─── SRE Configuration ─────────────────────────────────────────────────────
EMF_SRE_USERNAME=sre
EMF_SRE_PASSWORD=123
EMF_SRE_DEST_URL=http://sre-exporter-destination.orch-sre.svc.cluster.local:8428/api/v1/write

# ─── SMTP Configuration ────────────────────────────────────────────────────
EMF_SMTP_ADDRESS=smtp.serveraddress.com
EMF_SMTP_PORT=587
EMF_SMTP_HEADER="foo bar <foo@bar.com>"
EMF_SMTP_USERNAME=uSeR
EMF_SMTP_PASSWORD=T@123sfD
EMF_SMTP_DEV_MODE=true

# ─── Istio ──────────────────────────────────────────────────────────────────
EMF_ENABLE_ISTIO=false

# ─── Observability ──────────────────────────────────────────────────────────
# EMF_O11Y_SRE_LABEL=local
# EMF_O11Y_DEDICATED_EN=false

# ─── UI ─────────────────────────────────────────────────────────────────────
# EMF_CORS_ENABLED=true
# EMF_UI_INGRESS_INFRA=false
# EMF_UI_SESSION_TIMEOUT=3600

# ─── Feature Toggles (enable/disable specific components) ──────────────────
EMF_ENABLE_EMAIL=true
EMF_ENABLE_ISTIO=false
# EMF_ENABLE_PXE=true
# EMF_ENABLE_SQUID=false
# EMF_ENABLE_AWS_LB=false
# EMF_ENABLE_AWS_SM=false
# EMF_ENABLE_AUTOSCALER=false
# EMF_ENABLE_VPA=false
# EMF_DEFAULT_TENANCY=false
# EMF_TARGET_CLUSTER=onprem
