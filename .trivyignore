# AWS-0053: Load balancers use var.internal which is intentionally configurable
# Public exposure is expected for external-facing orchestrator endpoints
AWS-0053

# AWS-0079: Aurora RDS cluster already has storage_encrypted = true
# Trivy flags missing KMS CMK, but AWS default encryption is sufficient
AWS-0079

# AWS-0132: S3 CMK encryption - AWS default SSE-S3 encryption is enabled
# Customer managed keys require additional KMS infrastructure
AWS-0132

# AWS-0039: EKS secrets encryption requires a KMS key ARN
# Cluster uses private endpoint with no public access; secrets at rest
# are protected by EBS encryption at the node level
AWS-0039
